---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 28, height = 28, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="go-filewatcher logo">
  <rect width="28" height="28" rx="6" class="fill-[var(--color-accent)]" />
  <path d="M14 8C8 8 4 14 4 14C4 14 8 20 14 20C20 20 24 14 24 14C24 14 20 8 14 8Z" class="fill-none" stroke="#0c0a09" stroke-width="2" stroke-linejoin="round" />
  <circle cx="14" cy="14" r="3.5" class="fill-[#0c0a09]" />
  <circle cx="15" cy="13" r="1" class="fill-[var(--color-accent)]" />
</svg>
